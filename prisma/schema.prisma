generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon / Vercel Postgres use a pooled connection URL for the app and a
  // direct (non-pooled) URL for migrations. Set DIRECT_URL if your host
  // requires it (e.g. PgBouncer / Neon pooling).
  directUrl = env("DIRECT_URL")
}

// String field allowed values are documented inline.
// When migrating to PostgreSQL, convert these to native Prisma enums.

// ─── Auth (NextAuth.js Prisma Adapter) ────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  name          String?
  // NextAuth adapter fields
  emailVerified DateTime?
  image         String?
  // Extended profile
  passwordHash       String?
  // FREE | BASIC | PREMIUM
  subscriptionTier   String  @default("FREE")
  // ACTIVE | INACTIVE | TRIALING | PAST_DUE | CANCELED
  subscriptionStatus String  @default("INACTIVE")
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  location             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  familyProfile FamilyProfile?
  children      Child[]

  @@index([email])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

// ─── FamilyProfile ───────────────────────────────────────────────────────────

model FamilyProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  // BNC | MONTESSORI | UNSCHOOLING
  curriculum       String   @default("BNC")
  // ISLAM | CHRISTIANITY | JUDAISM | SECULAR
  faith            String   @default("SECULAR")
  faithIntegration Boolean  @default(false)
  // JSON string array e.g. ["Build confidence", "Prepare for GCSEs"]
  goals            String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Child ───────────────────────────────────────────────────────────────────

model Child {
  id            String   @id @default(cuid())
  userId        String
  name          String
  age           Int?
  yearGroup     String?
  learningStyle String?
  // JSON string array e.g. ["dinosaurs", "space"]
  interests        String @default("[]")
  dreamCareer      String?
  favouriteAnimals String?
  favouritePlaces  String?
  storyTypes       String?
  // EMERGING | DEVELOPING | SECURE | EXCEEDING
  literacyLevel  String   @default("DEVELOPING")
  numeracyLevel  String   @default("DEVELOPING")
  reasoningLevel String   @default("DEVELOPING")
  bloomStars     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessons            Lesson[]
  journalEntries     JournalEntry[]
  progress           Progress[]
  rewards            Reward[]
  badges             Badge[]
  externalActivities ExternalActivity[]

  @@index([userId])
}

// ─── Lesson ──────────────────────────────────────────────────────────────────

model Lesson {
  id           String    @id @default(cuid())
  childId      String
  subject      String
  topic        String
  dayDate      DateTime
  weekNumber   Int
  termNumber   Int
  durationMins Int       @default(60)
  startedAt    DateTime?
  completedAt  DateTime?
  // PENDING | IN_PROGRESS | COMPLETED | SKIPPED
  status           String   @default("PENDING")
  // JSON-encoded lesson plan returned by Claude
  generatedContent String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  child          Child             @relation(fields: [childId], references: [id], onDelete: Cascade)
  objectives     LessonObjective[]
  journalEntries JournalEntry[]

  @@index([childId])
  @@index([childId, weekNumber, termNumber])
  @@index([dayDate])
}

// ─── LessonObjective ─────────────────────────────────────────────────────────

model LessonObjective {
  id          String    @id @default(cuid())
  lessonId    String
  text        String
  completed   Boolean   @default(false)
  completedAt DateTime?

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

// ─── JournalEntry ────────────────────────────────────────────────────────────

model JournalEntry {
  id        String   @id @default(cuid())
  childId   String
  lessonId  String?
  title     String
  notes     String
  subject   String?
  // REGULAR | BREAKTHROUGH | DAY_OUT | CREATIVE | SPECIAL
  moment    String   @default("REGULAR")
  hasPhoto  Boolean  @default(false)
  photoUrl  String?
  // JSON string array e.g. ["maths", "outdoor"]
  tags      String   @default("[]")
  entryDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  child  Child   @relation(fields: [childId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([childId])
  @@index([childId, entryDate])
  @@index([lessonId])
  @@index([moment])
}

// ─── Progress ────────────────────────────────────────────────────────────────

model Progress {
  id              String   @id @default(cuid())
  childId         String
  subject         String
  topicsCompleted Int      @default(0)
  topicsTotal     Int      @default(0)
  objectivesMet   Int      @default(0)
  totalMinutes    Int      @default(0)
  lastUpdated     DateTime @default(now()) @updatedAt

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, subject])
  @@index([childId])
}

// ─── Reward ──────────────────────────────────────────────────────────────────

model Reward {
  id            String    @id @default(cuid())
  childId       String
  name          String
  starsRequired Int
  redeemed      Boolean   @default(false)
  redeemedAt    DateTime?
  createdAt     DateTime  @default(now())

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([childId, redeemed])
}

// ─── Badge ───────────────────────────────────────────────────────────────────

model Badge {
  id        String   @id @default(cuid())
  childId   String
  badgeType String
  earnedAt  DateTime @default(now())

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, badgeType])
  @@index([childId])
}

// ─── ExternalActivity ────────────────────────────────────────────────────────

model ExternalActivity {
  id           String   @id @default(cuid())
  childId      String
  description  String
  subject      String
  durationMins Int
  notes        String?
  // JSON string array e.g. ["count to 20", "identify shapes"]
  objectivesLinked String   @default("[]")
  activityDate     DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([childId, activityDate])
}
