# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get both URLs from your Neon project dashboard → Connection Details.
# DATABASE_URL  = pooled connection string (used by the app at runtime)
# DIRECT_URL    = direct (non-pooled) connection string (used by Prisma migrations)
DATABASE_URL="postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
# The full URL of your app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ─── Gemini (Google AI) ───────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/app/apikey (free tier available)
GEMINI_API_KEY=""
# Defaults to gemini-2.5-flash-lite (reliably available on free tier).
# Heavier models (gemini-2.5-flash, -pro) are often overloaded for free-tier
# projects; switch to them by enabling billing and setting:
# GEMINI_MODEL="gemini-2.5-pro"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Found at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Webhook signing secret — from `stripe listen` or Stripe dashboard
STRIPE_WEBHOOK_SECRET="whsec_..."
# Publishable key (safe to expose in the browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Stripe Price IDs ─────────────────────────────────────────────────────────
# Create products & prices in your Stripe dashboard, then paste the IDs here
STRIPE_BASIC_MONTHLY_PRICE_ID="price_..."
STRIPE_BASIC_ANNUAL_PRICE_ID="price_..."
STRIPE_PREMIUM_MONTHLY_PRICE_ID="price_..."
STRIPE_PREMIUM_ANNUAL_PRICE_ID="price_..."

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used for sitemap, OG tags, and Stripe redirect URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
